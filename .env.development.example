# Copy this file to .env.development.local for local development.
# Do not place production secrets in this file.

APP_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The browser posts to the local Next.js API route.
NEXT_PUBLIC_BOOKING_ENDPOINT=/api/bookings

# Safe default: booking submissions are simulated and do not send email,
# write production data, or contact the production Supabase project.
BOOKING_MODE=mock
BOOKING_UPSTREAM_URL=http://127.0.0.1:54321/functions/v1/submit-booking
BOOKING_UPSTREAM_AUTHORIZATION=
ALLOW_PRODUCTION_SERVICES=false

# Optional local Supabase instance
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional development-only email sink or test inbox
RESEND_API_KEY=
BOOKING_NOTIFICATION_EMAIL=development@example.test
