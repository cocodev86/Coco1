# Runtime environment
# Next.js sets NODE_ENV automatically. APP_ENV controls Metaphor behavior.
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Public application URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Browser requests stay on the application origin. The server route decides
# whether to mock the request or forward it to a configured non-production service.
NEXT_PUBLIC_BOOKING_ENDPOINT=/api/bookings
BOOKING_MODE=mock
BOOKING_UPSTREAM_URL=
BOOKING_UPSTREAM_AUTHORIZATION=
ALLOW_PRODUCTION_SERVICES=false

# Supabase integration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Transactional email
RESEND_API_KEY=
BOOKING_NOTIFICATION_EMAIL=

# Optional analytics and monitoring values belong here when enabled.
# Never commit production secrets or copy production credentials into development.
